
#!/usr/bin/env python3

"""
TITLE:
    Stochastic character mapping of somatic mutations 

AUTHORS:
    M. Tassia

DESCRIPTION:
    Application of stochastic character mapping to infer the evolutionary history of somatic mutations given:
    1. a phylogenetic tree (.nwk)
    2. a set of somatic mutations (.vcf)
    3. genotype substitution model (.model)
    This method leverages both the phylgoenetic tree and best-fit 10-state substitution model parameters output
    from CellPhy. 

USAGE: 
    snakemake --configfile config.yaml --profile /path/to/profile_dir/ -p # slurm
    snakemake --configfile config.yaml --use-conda --cores 16 -p # local
"""

#--- IMPORTS ---#
import pathlib

#--- CONFIGURATION ---#
# configure shell behavior for all rules
shell.executable("/bin/bash")
shell.prefix("set -euo pipefail;")

# Create a log directory
pathlib.Path("logs/").mkdir(parents=True, exist_ok=True)

#--- VARIABLES ---#
chrom = ["chr" + str(c) for c in list(range(1, 23))]

#--- RULES ---#
localrules:
    all,
    write_tree

rule all:
    input:
        expand("results/merged/{sample}.h5",
                sample=config["input"]["vcfs"].keys()),
        expand("results/trees/{sample}.scm.nwk",
                sample=config["input"]["vcfs"].keys())

rule scm_chromosome:
    input:
        tree = lambda wildcards: config["input"]["trees"][wildcards.sample],
        vcf = lambda wildcards: config["input"]["vcfs"][wildcards.sample],
        model = lambda wildcards: config["input"]["models"][wildcards.sample],
        script = "workflow/bin/chromosome_scm.R",
        functions = "workflow/bin/SCM.smk.R"
    output:
        h5 = temp("results/{sample}.{chrom}.h5")
    params:
        outgroup = lambda wildcards: config["input"]["outgroup"][wildcards.sample],
        prefix = "results/{sample}.{chrom}",
        reps = config["run_params"]["n_replicates"]
    resources:
        time = "24:00:00",
        mem_mb = config["run_params"]["mem_mb"]
    threads:
        config["run_params"]["n_threads"]
    conda:
        "envs/scm.yaml"
    shell:
        """
        Rscript {input.script} \
            -f {input.functions} \
            -v {input.vcf} \
            -t {input.tree} \
            -m {input.model} \
            -p {params.prefix} \
            -o {params.outgroup} \
            -n {threads} \
            -c {wildcards.chrom}
        """

rule merge_h5:
    input:
        h5_files = lambda wildcards: expand("results/{sample}.{chrom}.h5",
                          sample=wildcards.sample,      
                          chrom=chrom),
        script = "workflow/bin/merge_scm_h5.R",
        functions = "workflow/bin/SCM.smk.R"
    output:
        h5 = "results/merged/{sample}.h5"
    params:
        h5_files_str = lambda w, input:",".join(input.h5_files)
    resources:
        time = "1:00:00"
    conda:
        "envs/scm.yaml"
    shell:
        """
        Rscript {input.script} \
            -f {input.functions} \
            -i {params.h5_files_str} \
            -o {output.h5}
        """

rule write_tree:
    input:
        h5 = rules.merge_h5.output.h5,
        script = "workflow/bin/write_burden_to_tree.R",
        functions = "workflow/bin/SCM.smk.R",
        tree = lambda wildcards: config["input"]["trees"][wildcards.sample]
    output:
        tree = "results/trees/{sample}.scm.nwk"
    params: 
        outgroup = lambda wildcards: config["input"]["outgroup"][wildcards.sample],
    conda:
        "envs/scm.yaml"
    shell:
        """
        Rscript {input.script} \
           --functions {input.functions} \
           --input {input.h5} \
           --tree {input.tree} \
           --output {output.tree} \
           --outgroup {params.outgroup} \
           --merged
        """